# ===== データベース設定 =====
# SQLiteファイルのパス（デフォルト: ./zaiko.db）
DB_PATH=./zaiko.db

# ===== SMTP設定（メール送信用） =====
# 全項目を設定するとメール送信が有効になります
# 未設定の場合、メール送信はスキップされます
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@example.com

# ===== サーバー設定 =====
PORT=5000
